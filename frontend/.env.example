# ===========================================
# FRONTEND ENVIRONMENT CONFIGURATION
# Copy to .env.local and fill in your values.
# All NEXT_PUBLIC_* vars are exposed to the browser.
# ===========================================

# ─── API URLs ─────────────────────────────────────────────
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# For Vercel deployment: use same-origin proxy (no CORS needed)
# NEXT_PUBLIC_API_URL=/api/v1
# BACKEND_URL=https://your-backend-server.railway.app  # server-side only, used by Next.js rewrites (origin only, no /api/v1)

# ─── Facebook App IDs ─────────────────────────────────────
# Primary Messenger app (for page connection OAuth flow)
NEXT_PUBLIC_FACEBOOK_APP_ID=your_messenger_app_id
# Secondary app for Login with Facebook (optional, future use)
NEXT_PUBLIC_FACEBOOK_AUTH_APP_ID=your_auth_app_id

# ─── Build flag ───────────────────────────────────────────
# Set to 'true' when building inside Docker to enable Next.js standalone output
# NEXT_BUILD_STANDALONE=true
